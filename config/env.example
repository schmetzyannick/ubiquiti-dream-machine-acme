# Core ACME settings
ACME_ACCOUNT_EMAIL="you@example.com"

# Certificate request
CERT_DOMAIN="example.com"

# acme.sh DNS provider hook
DNS_PROVIDER="dns_ionos"

# IONOS web hosting / registrar DNS example
# Replace the placeholders and load this from an ignored local file.
IONOS_PREFIX="replace-with-real-ionos-prefix"
IONOS_SECRET="replace-with-real-ionos-secret"

# Optional Dream Machine deployment
UDM_HOST="X.X.X.X"
UDM_USER="root"
UDM_PASSWORD="replace-with-dream-machine-root-password"
# UDM_PORT="22"
# UDM_CERT_DIR="/data/unifi-core/config"
# UDM_RESTART_COMMAND="systemctl restart unifi-core"
